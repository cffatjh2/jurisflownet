        "manifest.phase6.json",
        "transforms.phase6.json",
        "id-maps.phase6.json",
        "verification.phase6.json",
        "sql/001_phase6_bootstrap.sql",
        "sql/010_identity_and_org.sql",
        "sql/020_clients_matters.sql",
        "sql/030_workflow.sql",
        "sql/040_trust.sql",
        "sql/050_billing.sql",
        "sql/060_documents_portal.sql",
        "sql/070_integrations.sql",
        "sql/090_verification.sql"
      ]
    },
    "B": {
      "name": "minimal-seed-onboarding",
      "description": "Legacy veri alinmadan canonical DB yalnizca seed tenant, admin ve sistem lookup seti ile acilir.",
      "requiredArtifacts": [
        "sql/100_minimal_seed_and_onboarding.template.sql"
      ]
    }
  },
