{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.Seq" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "Enrich": [ "FromLogContext" ],
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "Seq",
        "Args": {
          "serverUrl": "http://localhost:5341",
          "apiKey": ""
        }
      }
    ]
  },
  "AllowedHosts": "*",
  "Cors": {
    "AllowRenderSiblingOrigins": false,
    "AllowedOrigins": [
      "http://localhost:5173",
      "http://127.0.0.1:5173",
      "http://localhost:3000",
      "http://127.0.0.1:3000"
    ]
  },
  "ForwardedHeaders": {
    "Enabled": true,
    "ForwardLimit": 1,
    "RequireHeaderSymmetry": false,
    "TrustAllProxies": false,
    "AllowTrustAllProxiesInProduction": false,
    "KnownProxies": [],
    "KnownNetworks": []
  },
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=jurisflow.db"
  },
  "Database": {
    "Provider": "sqlite",
    "BootstrapMode": "migrate"
  },
  "Storage": {
    "Provider": "local",
    "Supabase": {
      "Url": "",
      "ServiceRoleKey": "",
      "Bucket": "jurisflow-files"
    }
  },
  "Jwt": {
    "Key": "",
    "Issuer": "JurisFlowServer",
    "Audience": "JurisFlowClient"
  },
  "Security": {
    "SessionTimeoutMinutes": 480,
    "IdleTimeoutMinutes": 60,
    "MfaChallengeMinutes": 10,
    "MfaEnforced": false,
    "AccessTokenMinutes": 30,
    "RefreshTokenDays": 30,
    "SessionRefreshThresholdMinutes": 30,
    "PasswordMinLength": 12,
    "PasswordRequireUpper": true,
    "PasswordRequireLower": true,
    "PasswordRequireDigit": true,
    "PasswordRequireSymbol": true,
    "BcryptWorkFactor": 12,
    "ContentSecurityPolicy": "default-src 'none'; frame-ancestors 'none'; base-uri 'none';",
    "DocumentEncryptionEnabled": false,
    "DocumentEncryptionKeyId": "primary",
    "DocumentEncryptionKey": "",
    "DbEncryptionEnabled": false,
    "DbEncryptionKey": "",
    "AuditLogImmutable": false,
    "AuditLogFailClosed": false,
    "AuditLogKey": "",
    "AuditLogQueue": {
      "Capacity": 4096,
      "DeadLetterCapacity": 1024,
      "MaxRetryAttempts": 5,
      "RetryDelaySeconds": 2
    },
    "LoginFailureLimitPerAccount": 5,
    "LoginFailureLimitPerIp": 20,
    "LoginFailureWindowMinutes": 15,
    "LoginLockoutMinutes": 15,
    "IntegrationSecrets": {
      "Provider": "config",
      "ActiveKeyId": "v1",
      "LegacyPlaintextAllowed": false,
      "BackfillOnStartup": true,
      "BackfillBatchSize": 500,
      "RotationEnabled": true,
      "RotationIntervalMinutes": 720,
      "Keys": {
        "v1": "MDEyMzQ1Njc4OWFiY2RlZjAxMjM0NTY3ODlhYmNkZWY="
      },
      "Kms": {
        "ActiveKeyId": "",
        "DataKeys": {}
      },
      "KeyVault": {
        "ActiveKeyId": "",
        "DataKeys": {}
      }
    }
  },
  "RateLimiting": {
    "AuthLogin": {
      "PermitLimit": 8,
      "WindowSeconds": 60
    },
    "AuthMfa": {
      "PermitLimit": 10,
      "WindowSeconds": 60
    },
    "AuthRefresh": {
      "PermitLimit": 30,
      "WindowSeconds": 60
    },
    "BootstrapRead": {
      "PermitLimit": 24,
      "WindowSeconds": 60
    },
    "TaskRead": {
      "PermitLimit": 60,
      "WindowSeconds": 60
    },
    "TaskMutation": {
      "PermitLimit": 40,
      "WindowSeconds": 60
    },
    "IntegrationWebhook": {
      "PermitLimit": 120,
      "WindowSeconds": 60
    }
  },
  "Backup": {
    "EncryptBackups": true,
    "EncryptionKey": "",
    "AllowRestore": false
  },
  "Deadlines": {
    "RemindersEnabled": true,
    "ReminderIntervalMinutes": 60
  },
  "Holidays": {
    "SeedEnabled": true,
    "SeedStartYear": 2024,
    "SeedYearsAhead": 3
  },
  "Signatures": {
    "DefaultExpiryDays": 30,
    "ReminderEnabled": true,
    "ReminderCadenceDays": 3,
    "MaxReminders": 3
  },
  "Operations": {
    "JobsEnabled": true,
    "JobIntervalMinutes": 5,
    "PaymentPlanBatchSize": 25,
    "IntegrationSyncIntervalMinutes": 60,
    "IntegrationSyncBatchSize": 10
  },
  "Email": {
    "Enabled": false,
    "FromAddress": "",
    "Smtp": {
      "Host": "",
      "Port": 587,
      "Username": "",
      "Password": "",
      "UseTls": true
    }
  },
  "Stripe": {
    "SecretKey": "",
    "WebhookSecret": "",
    "PublishableKey": "",
    "SuccessUrl": "http://localhost:3000/billing?payment=success",
    "CancelUrl": "http://localhost:3000/billing?payment=cancel",
    "StatementDescriptor": "JURISFLOW"
  },
  "Payments": {
    "AllowedCurrencies": [ "USD" ]
  },
  "Integrations": {
    "Google": {
      "ClientId": "",
      "ClientSecret": "",
      "RedirectUri": "",
      "GmailWebhookChannelToken": ""
    },
    "Outlook": {
      "ClientId": "",
      "ClientSecret": "",
      "TenantId": "common",
      "RedirectUri": "",
      "Scopes": "offline_access Calendars.Read Mail.Read User.Read",
      "WebhookClientState": ""
    },
    "QuickBooks": {
      "ClientId": "",
      "ClientSecret": "",
      "RedirectUri": "",
      "ApiBaseUrl": "https://quickbooks.api.intuit.com",
      "WebhookVerifierToken": ""
    },
    "Xero": {
      "ClientId": "",
      "ClientSecret": "",
      "RedirectUri": "",
      "WebhookSigningKey": ""
    },
    "CourtListener": {
      "ApiBaseUrl": "https://www.courtlistener.com/api/rest/v4",
      "RequirePolicyAcknowledgement": false
    },
    "EfilingPartners": {
      "OneLegal": {
        "ApiBaseUrl": "",
        "ValidatePath": "/health",
        "SyncPath": "/submissions",
        "SubmitPath": "/submissions",
        "StrictCourtCoverage": false,
        "SupportedCourtTypes": [],
        "RequirePdfOnly": true,
        "MaxPacketDocuments": 25,
        "RequiredMetadataKeys": [ "caseNumber", "partyRole", "filingType" ]
      },
      "FileAndServeXpress": {
        "ApiBaseUrl": "",
        "ValidatePath": "/health",
        "SyncPath": "/submissions",
        "SubmitPath": "/submissions",
        "StrictCourtCoverage": false,
        "SupportedCourtTypes": [],
        "RequirePdfOnly": true,
        "MaxPacketDocuments": 25,
        "RequiredMetadataKeys": [ "caseNumber", "partyRole", "filingType" ]
      }
    },
    "Zoom": {
      "AccountId": "",
      "ClientId": "",
      "ClientSecret": "",
      "RedirectUri": "",
      "WebhookSecret": ""
    },
    "Gemini": {
      "ApiKey": ""
    },
    "Webhooks": {
      "AllowUnsigned": false
    },
    "Operations": {
      "KillSwitch": {
        "GlobalEnabled": false,
        "GlobalReason": "",
        "DisabledTenants": [],
        "DisabledProviders": [],
        "TenantOverrides": {}
      },
      "RetryPolicy": {
        "MaxAttempts": 3,
        "BaseDelaySeconds": 5,
        "MaxDelaySeconds": 120,
        "BackoffMultiplier": 2.0,
        "JitterPercent": 20,
        "MinSyncIntervalSeconds": 0,
        "Providers": {
          "quickbooks-online": {
            "BaseDelaySeconds": 10,
            "MaxDelaySeconds": 300
          },
          "xero": {
            "BaseDelaySeconds": 10,
            "MaxDelaySeconds": 300
          },
          "courtlistener-dockets": {
            "BaseDelaySeconds": 15,
            "MaxDelaySeconds": 300
          },
          "courtlistener-recap": {
            "BaseDelaySeconds": 15,
            "MaxDelaySeconds": 300
          }
        }
      },
      "PiiMinimization": {
        "WebhookPayloadMaxChars": 8192,
        "MaxArrayItems": 50,
        "MaxStringLength": 512
      }
    }
  },
  "Efiling": {
    "PacketPrecheck": {
      "MaxDocumentMb": 25,
      "RequireCourtRuleCoverage": false
    }
  },
  "AppDirectory": {
    "DefaultSlaTier": "standard",
    "DefaultResponseHours": 24,
    "DefaultResolutionHours": 72,
    "DefaultUptimePercent": 99.5,
    "AutoPublishApproved": false
  },
  "Seed": {
    "Enabled": false,
    "AdminEmail": "",
    "AdminPassword": "",
    "ResetPasswords": false
  },
  "Tenancy": {
    "DefaultTenantName": "JurisFlow Legal",
    "DefaultTenantSlug": "ahmet-hukuk"
  },
  "Features": {
    "RefactorWave": {
      "UseLegacyTaskAssignmentAdapter": false,
      "UseLegacyMatterResponsibilityAdapter": true,
      "UseTenantCompanySynchronization": true,
      "RestrictLeadDeleteToPrivilegedRoles": true
    }
  }
}
