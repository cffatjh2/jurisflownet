{
  "name": "jurisflow---legal-practice-management",
  "private": true,
  "version": "0.0.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "type": "module",
  "scripts": {
    "dev": "npm run server & vite",
    "dev:frontend": "vite",
    "build": "vite build && npx prisma generate",
    "typecheck": "tsc --noEmit",
    "lint": "npm run typecheck",
    "test": "vitest run",
    "start": "node --import tsx server/index.ts",
    "start:prod": "node --import tsx server/index.ts",
    "preview": "vite preview",
    "server": "tsx server/index.ts",
    "postinstall": "prisma generate",
    "prisma:generate": "prisma generate",
    "prisma:push": "prisma db push",
    "setup-admin": "tsx scripts/setup-admin.ts",
    "add-admins": "tsx scripts/add-admins.ts",
    "list-admins": "tsx scripts/list-admins.ts",
    "check-login": "tsx scripts/check-login.ts"
  },
  "dependencies": {
    "@google/genai": "^1.32.0",
    "@hello-pangea/dnd": "^18.0.1",
    "@prisma/client": "5.15.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "express": "^5.2.1",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "google-auth-library": "^10.5.0",
    "googleapis": "^168.0.0",
    "helmet": "^7.1.0",
    "html2canvas": "^1.4.1",
    "jsonwebtoken": "^9.0.2",
    "jspdf": "^4.2.0",
    "mammoth": "^1.6.0",
    "pdfkit": "^0.14.0",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "recharts": "^3.5.1",
    "tesseract.js": "^7.0.0",
    "tsx": "^4.0.0",
    "typescript": "~5.8.2",
    "winston": "^3.11.0"
  },
  "overrides": {
    "rimraf": "^6.1.3",
    "glob": "^13.0.6",
    "minimatch": "^10.2.2"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/html2canvas": "^0.5.35",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^22.14.0",
    "@types/pdfkit": "^0.13.5",
    "@vitejs/plugin-react": "^5.0.0",
    "prisma": "5.15.0",
    "vite": "^6.2.0",
    "vitest": "^3.2.4"
  }
}
