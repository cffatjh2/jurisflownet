# Supabase-backed backend settings for a fresh deployment.
ASPNETCORE_ENVIRONMENT=Production
Cors__AllowedOriginsCsv=https://your-frontend-domain.com

Database__Provider=postgres
# For the current codebase, PostgreSQL defaults to ensure-created so a fresh Supabase DB
# can be bootstrapped without replaying the existing SQLite migrations.
Database__BootstrapMode=ensure-created
# Use the Session Pooler host/port on Railway or any IPv4-only network.
ConnectionStrings__DefaultConnection=Host=aws-0-us-east-1.pooler.supabase.com;Port=5432;Database=postgres;Username=postgres.your-project-ref;Password=replace-me;SSL Mode=Require

Storage__Provider=supabase
Storage__Supabase__Url=https://your-project-ref.supabase.co
Storage__Supabase__ServiceRoleKey=replace-with-your-supabase-service-role-key
Storage__Supabase__Bucket=jurisflow-files

Jwt__Key=replace-with-a-random-secret-at-least-32-characters
Jwt__Issuer=JurisFlowServer
Jwt__Audience=JurisFlowClient

Security__MfaEnforced=true
Security__DocumentEncryptionEnabled=true
Security__DbEncryptionEnabled=true
Security__AuditLogImmutable=true
Security__AuditLogFailClosed=true

Security__DocumentEncryptionKey=<base64-encoded-32-byte-key>
Security__DbEncryptionKey=<base64-encoded-32-byte-key>
Security__AuditLogKey=<base64-encoded-key-at-least-32-bytes>

Security__IntegrationSecrets__Provider=config
Security__IntegrationSecrets__LegacyPlaintextAllowed=false
Security__IntegrationSecrets__ActiveKeyId=railway-v1
Security__IntegrationSecrets__Keys__railway-v1=<base64-encoded-32-byte-key>

Seed__Enabled=true
Seed__AdminEmail=admin@jurisflow.local
Seed__AdminPassword=ChangeMe123!Abc
Seed__ResetPasswords=true

Tenancy__DefaultTenantSlug=default
Tenancy__DefaultTenantName=JurisFlow Legal

LemonSqueezy__ApiKey=
LemonSqueezy__StoreId=
LemonSqueezy__Starter39VariantId=
LemonSqueezy__AllInclusive59VariantId=
LemonSqueezy__Starter39CheckoutUrl=
LemonSqueezy__AllInclusive59CheckoutUrl=
LemonSqueezy__SuccessUrl=https://your-frontend-domain.com/login?signup=success
LemonSqueezy__TestMode=false
